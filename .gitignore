# Whitelist only app folders committed: client/, server/, and deploy glue at repo root.
/*
!.gitignore
!/.dockerignore
!/.github/
!/Dockerfile
!/client/
!/server/

# GitHub Actions (not under client/server)
!/.github/**

# Must un-ignore all paths under allowed dirs (see gitignore(5) parent ignore rules).
!/client/**
!/server/**
